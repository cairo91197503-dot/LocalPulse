# Set default behavior to handle line endings automatically.
* text=auto

# Force Unix (LF) line endings for source code and configurations
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
gradlew text eol=lf
*.sh text eol=lf

# Force Windows (CRLF) line endings for batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Declare binary files to keep them unmodified
*.jar binary
*.bin binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.keystore binary
*.flat binary
