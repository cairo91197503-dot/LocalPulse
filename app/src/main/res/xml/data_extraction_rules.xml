<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Excluir SharedPreferences do backup na nuvem -->
        <exclude domain="sharedpref" path="pulse_prefs.xml"/>
        <exclude domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <!-- Excluir SharedPreferences da transferência entre dispositivos -->
        <exclude domain="sharedpref" path="pulse_prefs.xml"/>
        <exclude domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>
